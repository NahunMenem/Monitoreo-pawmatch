# Google Identity Services (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# NextAuth secret (run: openssl rand -base64 32)
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3001

# PawMatch backend
NEXT_PUBLIC_BACKEND_URL=https://petmatch-back-production.up.railway.app
BACKEND_URL=https://petmatch-back-production.up.railway.app
